<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<SplitPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.tallerbici.viewController.MecanicoController"
           orientation="HORIZONTAL" dividerPositions="0.4"
           style="-fx-padding: 10;">

    <VBox spacing="12" style="-fx-padding: 15; -fx-background-color: white;
                               -fx-background-radius: 8; -fx-effect: dropshadow(gaussian,#ccc,4,0,0,2);">
        <Label text="Registrar Mecánico"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A237E;"/>
        <Separator/>

        <Label text="Código Interno *"/>
        <TextField fx:id="txtCodigo" promptText="Ej: MEC-003"/>

        <Label text="Nombre Completo *"/>
        <TextField fx:id="txtNombre" promptText="Ej: Julián Pérez"/>

        <Label text="Especialidad *"/>
        <ComboBox fx:id="cmbEspecialidad" maxWidth="Infinity" editable="true"
                  promptText="Seleccionar o escribir especialidad"/>

        <Label text="Número de Certificación *"/>
        <TextField fx:id="txtCertificacion" promptText="Ej: CERT-2024-030"/>

        <Button fx:id="btnAccion" text="✅ Registrar Mecánico"
                onAction="#accionPrincipal" maxWidth="Infinity"
                style="-fx-background-color: #1A237E; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button fx:id="btnLimpiar" text="🗑 Limpiar"
                onAction="#limpiarFormulario" maxWidth="Infinity"
                style="-fx-background-color: #757575; -fx-text-fill: white;"/>
        <Label fx:id="lblMensaje" text="" wrapText="true"
               style="-fx-font-size: 12px; -fx-text-fill: #388E3C;"/>
    </VBox>

    <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: white;
                               -fx-background-radius: 8; -fx-effect: dropshadow(gaussian,#ccc,4,0,0,2);">
        <Label text="Mecánicos Disponibles"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A237E;"/>
        <Separator/>
        <ListView fx:id="listMecanicos" VBox.vgrow="ALWAYS"
                  onMouseClicked="#mostrarDetalleMecanico"/>
        <TextArea fx:id="txtDetalleMecanico" editable="false" prefRowCount="5"
                  style="-fx-font-family: monospace; -fx-font-size: 12px;"
                  promptText="Selecciona un mecánico para ver su detalle..."/>
    </VBox>

</SplitPane>