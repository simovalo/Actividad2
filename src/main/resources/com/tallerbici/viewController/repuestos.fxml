<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<SplitPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.tallerbici.viewController.RepuestosController"
           orientation="HORIZONTAL" dividerPositions="0.42"
           style="-fx-padding: 10;">

    <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: white;
                               -fx-background-radius: 8; -fx-effect: dropshadow(gaussian,#ccc,4,0,0,2);">
        <Label text="⚙ Gestión de Stock de Repuestos"
               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1A237E;"/>
        <Label text="📌 Funcionalidad Propia"
               style="-fx-text-fill: #7E57C2; -fx-font-style: italic;"/>
        <Label fx:id="lblModoEdicion" text=""
               style="-fx-text-fill: #E65100; -fx-font-weight: bold; -fx-font-size: 11px;"/>
        <Separator/>

        <Label text="Código *"/>
        <TextField fx:id="txtCodigo" promptText="Ej: REP-004"/>

        <Label text="Nombre del Repuesto *"/>
        <TextField fx:id="txtNombre" promptText="Ej: Cable de cambios Shimano"/>

        <Label text="Categoría *"/>
        <ComboBox fx:id="cmbCategoria" maxWidth="Infinity" editable="true"
                  promptText="Ej: Frenos, Transmisión..."/>

        <Label text="Precio Unitario ($) *"/>
        <TextField fx:id="txtPrecio" promptText="Ej: 45000"/>

        <HBox spacing="10">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Stock Inicial"/>
                <Spinner fx:id="spinnerStock" min="0" max="9999" initialValue="10"
                         editable="true" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Stock Mínimo"/>
                <Spinner fx:id="spinnerMinimo" min="1" max="100" initialValue="3"
                         editable="true" maxWidth="Infinity"/>
            </VBox>
        </HBox>

        <Button fx:id="btnAccion" text="✅ Registrar Repuesto"
                onAction="#accionPrincipal" maxWidth="Infinity"
                style="-fx-background-color: #1A237E; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button text="🗑 Limpiar / Cancelar"
                onAction="#limpiarFormulario" maxWidth="Infinity"
                style="-fx-background-color: #757575; -fx-text-fill: white;"/>

        <Separator/>
        <Label text="Ajuste de Stock" style="-fx-font-weight: bold;"/>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <TextField fx:id="txtCodigoAjuste" promptText="Código del repuesto"
                       HBox.hgrow="ALWAYS"/>
            <Spinner fx:id="spinnerAjuste" min="1" max="9999" initialValue="1"
                     editable="true" prefWidth="80"/>
        </HBox>
        <HBox spacing="8">
            <Button text="➕ Agregar Stock" onAction="#agregarStock" HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    style="-fx-background-color: #388E3C; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button text="➖ Usar Stock" onAction="#usarStock" HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    style="-fx-background-color: #F57C00; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </HBox>
        <Label fx:id="lblMensaje" text="" wrapText="true" style="-fx-font-size: 12px;"/>
    </VBox>

    <VBox spacing="8" style="-fx-padding: 15; -fx-background-color: white;
                              -fx-background-radius: 8; -fx-effect: dropshadow(gaussian,#ccc,4,0,0,2);">
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="Inventario de Repuestos"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A237E;"/>
            <Button text="⚠ Ver Alertas" onAction="#verAlertas"
                    style="-fx-background-color: #E53935; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button text="🔄 Actualizar" onAction="#refrescarLista"
                    style="-fx-background-color: #455A64; -fx-text-fill: white;"/>
        </HBox>
        <Separator/>
        <Label fx:id="lblAlertas" text="" wrapText="true"
               style="-fx-text-fill: #C62828; -fx-font-weight: bold;"/>
        <ListView fx:id="listRepuestos" VBox.vgrow="ALWAYS"
                  onMouseClicked="#mostrarDetalleRepuesto"/>
        <Button text="✏ Editar Seleccionado"
                onAction="#editarSeleccionado" maxWidth="Infinity"
                style="-fx-background-color: #283593; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <TextArea fx:id="txtDetalleRepuesto" editable="false" prefRowCount="4"
                  style="-fx-font-family: monospace; -fx-font-size: 12px;"
                  promptText="Clic en un repuesto para ver su detalle..."/>
    </VBox>

</SplitPane>